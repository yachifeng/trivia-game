<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.triviagame.GameOverController" style="-fx-background-color: #2c3e50;">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Game Over" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <VBox alignment="CENTER" spacing="10.0">
        <Label text="Your Final Score:" style="-fx-font-size: 20px; -fx-text-fill: #ecf0f1;"/>
        <Label fx:id="scoreLabel" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #f1c40f;"/>
    </VBox>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="restartButton" text="Play Again" onAction="#handleRestart"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16px;" prefWidth="150"/>
        <Button fx:id="mainMenuButton" text="Main Menu" onAction="#handleReturnToMenu"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 16px;" prefWidth="150"/>
    </HBox>
</VBox>