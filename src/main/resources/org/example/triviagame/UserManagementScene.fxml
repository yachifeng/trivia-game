<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.triviagame.UserManagementController">
    <children>
        <Button layoutX="520.0" layoutY="361.0" mnemonicParsing="false" onAction="#handleGoBack" text="Back to Tools" />
        <Label layoutX="206.0" layoutY="14.0" text="User Management">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <TableView fx:id="userTable" layoutX="104.0" layoutY="50.0" prefHeight="250.0" prefWidth="400">
            <columns>
                <TableColumn fx:id="usernameColumn" prefWidth="264.0" text="Username" />
                <TableColumn fx:id="roleColumn" prefWidth="135.0" text="Role" />
            </columns>
        </TableView>
      <HBox alignment="CENTER" layoutX="154.0" layoutY="312.0" prefHeight="49.0" prefWidth="300.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handlePromote" text="Promote" />
            <Button mnemonicParsing="false" onAction="#handleDemote" text="Demote" />
            <Button mnemonicParsing="false" onAction="#handleDelete" text="Delete" />
         </children>
      </HBox>
    </children>
</AnchorPane>
